{
  "expo": {
    "name": "CCNA Quest",
    "slug": "ccnaquest",
    "version": "1.0.0",
    "scheme": "ccnaquest",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1a20"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cawarden.ccnaquest",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.cawarden.ccnaquest",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e1a20"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "subnet-studio-6c"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f559b24c-97e0-4821-9e4b-5d7d29e0f012"
      }
    },
    "owner": "ccnaquest"
  }
}
